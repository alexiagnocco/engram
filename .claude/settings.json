{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/prompt-activity-marker.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/prompt-boot-reminder.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/prompt-manifest-stale.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-bash-vault-delete-guard.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-bash-vault-stash-guard.sh" }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-write-vault-check.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-activity-log.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-lint.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-hygiene.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-log-session.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-vault-sync.sh" },
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-wrap-reminder.sh" }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-end-log.sh" }
        ]
      }
    ]
  }
}
